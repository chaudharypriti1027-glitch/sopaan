{
  "name": "@sopaan/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Sopaan mobile app — React Native (Expo)",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "bash scripts/with-jdk.sh expo run:android",
    "android:clean": "bash scripts/with-jdk.sh bash -lc 'cd android && ./gradlew clean'",
    "android:free-space": "bash scripts/free-android-build-space.sh",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "lint": "eslint src",
    "i18n:check": "node scripts/check-i18n-strings.mjs",
    "typecheck": "tsc --noEmit",
    "test:perf": "jest src/perf/__tests__",
    "e2e:prebuild:android": "expo prebuild --platform android --no-install",
    "e2e:build:android": "npm run e2e:prebuild:android && bash scripts/with-jdk.sh bash -lc 'cd android && ./gradlew assembleDebug -x lint -x test'",
    "e2e:prebuild:ios": "expo prebuild --platform ios --no-install",
    "e2e:maestro": "maestro test .maestro/flows",
    "e2e:maestro:smoke": "maestro test .maestro/flows/smoke-logged-in.yaml .maestro/flows/05-premium-paywall-sandbox.yaml",
    "update:staging": "eas update --profile staging --non-interactive --message",
    "update:production": "eas update --profile production --non-interactive --message",
    "update:rollout-10": "eas update --profile production-rollout-10 --non-interactive --message",
    "update:rollout-50": "eas update --profile production-rollout-50 --non-interactive --message",
    "update:rollback": "eas update:rollback",
    "sentry:sourcemaps": "echo 'Source maps upload on EAS build when SENTRY_AUTH_TOKEN is set. Runtime release: sopaan-mobile@<version>'"
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@livekit/react-native": "^2.11.1",
    "@livekit/react-native-webrtc": "^144.1.1",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "8.4.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.18.3",
    "@react-navigation/native": "^7.3.4",
    "@react-navigation/native-stack": "^7.17.6",
    "@sentry/react-native": "~6.14.0",
    "@shopify/flash-list": "1.7.6",
    "@tanstack/query-async-storage-persister": "^5.101.1",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-query-persist-client": "^5.101.1",
    "axios": "^1.18.1",
    "babel-preset-expo": "~13.0.0",
    "expo": "~53.0.12",
    "expo-application": "~6.1.5",
    "expo-auth-session": "~6.2.1",
    "expo-clipboard": "~7.1.5",
    "expo-constants": "~17.1.8",
    "expo-crypto": "~14.1.5",
    "expo-device": "~7.1.4",
    "expo-file-system": "^18.1.11",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.1",
    "expo-image-picker": "~16.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.4",
    "expo-notifications": "~0.31.5",
    "expo-secure-store": "~14.2.4",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-updates": "~0.28.18",
    "expo-web-browser": "~14.2.0",
    "i18next": "^26.3.3",
    "livekit-client": "^2.20.0",
    "lucide-react-native": "^1.21.0",
    "react": "19.0.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-razorpay": "^3.0.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-view-shot": "^4.0.3",
    "react-native-webview": "13.13.5",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.0.14",
    "eslint": "^9.28.0",
    "eslint-config-expo": "^9.2.0",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.7",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.8.3"
  }
}
