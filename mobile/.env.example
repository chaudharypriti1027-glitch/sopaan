# API origin for physical devices / custom setups (no trailing slash, no /api suffix).
# The app appends /api automatically — e.g. http://192.168.1.42:4000
# Leave empty to auto-detect from the Expo Metro host (emulator uses 10.0.2.2:4000).
EXPO_PUBLIC_API_URL=

# Sentry error tracking (optional — disabled when unset)
# EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# EXPO_PUBLIC_SENTRY_ENVIRONMENT=development
# EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
#
# EAS builds: set SENTRY_AUTH_TOKEN as an EAS secret (never commit).
# Source maps upload automatically via @sentry/react-native/expo + babel plugin.
# Release tag at runtime: sopaan-mobile@<app.json version>, dist = native build number.
#
# Verify in dev: Settings → Send Sentry test error (when DSN is set).

# Google Sign-In (OAuth client IDs from Google Cloud Console)
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=<web-client-id>.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=<ios-client-id>.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=<android-client-id>.apps.googleusercontent.com

# Razorpay: not needed in the mobile app — the server returns the public key_id
# when you call POST /api/payments/create-order. Configure keys in server/.env only.
