{
  "name": "@sopaan/server",
  "version": "0.1.0",
  "private": true,
  "description": "Sopaan REST API — Express.js + MongoDB",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:worker": "node src/worker.js",
    "dev": "node scripts/dev-server.mjs",
    "seed": "node src/seed/index.js",
    "ensure-admin": "node src/seed/ensureAdmin.js",
    "test": "node ../scripts/clean-appledouble.mjs && NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "lint": "node ../scripts/clean-appledouble.mjs && eslint src tests",
    "validate": "npm run lint && npm run test",
    "verify:indexes": "node scripts/verify-indexes.js",
    "backup:mongodb": "bash scripts/backup/mongodb-backup.sh",
    "backup:restore": "bash scripts/backup/mongodb-restore.sh",
    "backup:verify-restore": "node scripts/backup/verify-restore.js",
    "backup:secrets-inventory": "node scripts/backup/secrets-inventory.js",
    "check:s3": "node scripts/check-s3.mjs",
    "create:s3": "node scripts/create-s3-bucket.mjs",
    "audit:deps": "npm audit --audit-level=high",
    "sentry:sourcemaps": "node --input-type=module -e \"console.log('Upload with: sentry-cli releases files', process.env.SENTRY_RELEASE || 'sopaan-api@0.1.0', 'upload-sourcemaps ./dist')\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0",
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@sentry/node": "^9.47.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.1",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.15.5",
    "mongoose": "^8.16.0",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "nanoid": "^5.1.16",
    "node-cron": "^3.0.3",
    "nodemailer": "^9.0.3",
    "rate-limit-redis": "^4.3.1",
    "sanitize-html": "^2.17.5",
    "socket.io": "^4.8.3",
    "zod": "^3.25.67"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "supertest": "^7.1.1"
  }
}
