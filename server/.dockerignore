# Build context: server/ (used by server/Dockerfile and Render rootDir: server)
.git
.gitignore
**/.DS_Store

node_modules
**/node_modules

# Local env & secrets — inject at runtime
.env
.env.*
!.env.example
!.env.docker.example
!.env.staging.example

# Tests & dev tooling
tests
coverage
**/*.test.js
**/__tests__

# Backups & logs
backups
**/*.log
npm-debug.log*

# Documentation (not needed at runtime)
**/*.md
!docs/DEPLOY.md
