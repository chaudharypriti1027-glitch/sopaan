# =============================================================================
# Sopaan API — environment variables
# Copy to server/.env (local) or inject via your host secret manager (staging/prod).
# Production: NODE_ENV=production requires all keys marked [production required].
# Development: set DEV_STUB_AI=true to skip Anthropic calls locally.
# =============================================================================

# [required] HTTP port the API listens on
PORT=4000

# [required] MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/sopaan

# [required] JWT signing secrets — min 32 chars each in production; must differ
JWT_SECRET=<random-long-string-min-32-chars>
JWT_REFRESH_SECRET=<different-random-long-string-min-32-chars>
# JWT_ACCESS_EXPIRY=15m
# JWT_REFRESH_EXPIRY=30d

# [required] Runtime: development | production | test
NODE_ENV=development

# Deploy target: development | staging | production | e2e (defaults from NODE_ENV)
# DEPLOY_ENV=development

# [required] Allowed client origin for CORS (Expo dev server or production app URL)
CLIENT_URL=http://localhost:8081

# -----------------------------------------------------------------------------
# AI (Anthropic Claude)
# -----------------------------------------------------------------------------

# [production required] Anthropic API key for doubts, test generation, coach, CA summaries
ANTHROPIC_API_KEY=<your-claude-api-key>
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# [dev only] Deterministic AI stubs — never set in production (server will refuse to boot)
# DEV_STUB_AI=true

# Per-user AI abuse guard (requests per minute across /api/ai/*)
# AI_REQUESTS_PER_MINUTE=12

# -----------------------------------------------------------------------------
# Payments (Razorpay — India)
# -----------------------------------------------------------------------------

# [production required] Razorpay live keys from dashboard
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
# RAZORPAY_KEY_SECRET=<razorpay-live-secret>

# [production required] Webhook signing secret (Dashboard → Webhooks)
# RAZORPAY_WEBHOOK_SECRET=<razorpay-webhook-secret>

# PREMIUM_MONTHLY_AMOUNT_PAISE=29900
# PREMIUM_YEARLY_AMOUNT_PAISE=249900

# -----------------------------------------------------------------------------
# Current affairs (NewsAPI.ai)
# -----------------------------------------------------------------------------

# [production required] Live news articles for mobile current-affairs tab
# NEWSAPI_AI_KEY=<your-newsapi-ai-key>
# NEWSAPI_AI_BASE_URL=https://eventregistry.org/api/v1/article/getArticles
# NEWSAPI_AI_ALL_MONTHS_LOOKBACK=6

# Daily RSS digest (optional; runs when CA_DIGEST_ENABLED=true)
# CA_DIGEST_ENABLED=true
# CA_DIGEST_SOURCES=[{"id":"pib-english","name":"PIB","feedUrl":"https://pib.gov.in/RssEnglish.aspx","enabled":true,"maxItemsPerRun":5}]

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------

# [production required] Sentry DSN for error tracking
# SENTRY_DSN=https://<publicKey>@o<org>.ingest.sentry.io/<project>
# SENTRY_RELEASE=sopaan-api@0.1.0
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_TEST_SECRET=<random-secret-for-verifying-sentry-in-prod>
# OBSERVABILITY_ENABLED=true
# METRICS_TOKEN=<metrics-scrape-token>
# METRICS_PATH=/metrics

# -----------------------------------------------------------------------------
# Cache, jobs, rate limits (optional — in-memory fallback if Redis absent)
# -----------------------------------------------------------------------------

# REDIS_URL=redis://127.0.0.1:6379
# REDIS_ENABLED=true
# REDIS_KEY_PREFIX=sopaan:
# API_RATE_LIMIT_MAX=100
# CACHE_TTL_EXAM_CALENDAR_SEC=300
# CACHE_TTL_CA_LIST_SEC=120
# CACHE_TTL_LEADERBOARD_SEC=60

# Background job scheduler (node-cron, Asia/Kolkata by default)
# JOBS_ENABLED=true
# JOBS_TIMEZONE=Asia/Kolkata
# PROCESS_ROLE=all|api|worker|scheduler  (see server/docs/DEPLOY.md)

# -----------------------------------------------------------------------------
# Push notifications (optional)
# -----------------------------------------------------------------------------

# EXPO_ACCESS_TOKEN=<expo-access-token-for-higher-push-limits>

# -----------------------------------------------------------------------------
# Live class streaming (optional — LiveKit)
# -----------------------------------------------------------------------------

# STREAMING_PROVIDER=livekit
# LIVEKIT_API_KEY=<livekit-api-key>
# LIVEKIT_API_SECRET=<livekit-api-secret>
# LIVEKIT_URL=wss://<project>.livekit.cloud
# LIVEKIT_RECORDING_BASE_URL=https://cdn.example.com/live-recordings

# -----------------------------------------------------------------------------
# Semantic search embeddings (optional)
# -----------------------------------------------------------------------------

# EMBEDDING_PROVIDER=voyage
# VOYAGE_API_KEY=<your-voyage-api-key>
# EMBEDDING_MODEL=voyage-3-lite
# EMBEDDING_DIMENSIONS=512

# -----------------------------------------------------------------------------
# Auth hardening
# -----------------------------------------------------------------------------

# Google Sign-In — verify ID tokens from mobile (comma-separated client IDs)
# GOOGLE_CLIENT_ID=<web-client-id>.apps.googleusercontent.com
# GOOGLE_CLIENT_IDS=<ios-client-id>.apps.googleusercontent.com,<android-client-id>.apps.googleusercontent.com,<web-client-id>.apps.googleusercontent.com

# AUTH_MAX_LOGIN_ATTEMPTS=5
# AUTH_LOCKOUT_MS=900000
# TRUST_PROXY=true
# FORCE_HTTPS=true

# -----------------------------------------------------------------------------
# Avatar uploads
# -----------------------------------------------------------------------------

# AVATAR_STORAGE_PROVIDER=dev
# Or set CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_AVATAR_FOLDER=sopaan/avatars
# CLOUDINARY_UPLOAD_FOLDER=sopaan/uploads
# AWS_S3_BUCKET=
# AWS_REGION=ap-south-1

# -----------------------------------------------------------------------------
# Mobile app version policy
# -----------------------------------------------------------------------------

# APP_MIN_NATIVE_VERSION=0.1.0
# APP_UPDATE_CHANNEL=production
# APP_ANDROID_STORE_URL=https://play.google.com/store/apps/details?id=com.sopaan.app

# -----------------------------------------------------------------------------
# Referrals & free tier
# -----------------------------------------------------------------------------

# REFERRAL_LINK_BASE=https://sopaan.app/refer
# FREE_AI_TESTS_PER_DAY=2
# FREE_AI_DOUBTS_PER_DAY=10
# FREE_AI_EVALUATIONS_PER_DAY=0
# AI_GLOBAL_DAILY_TOKEN_BUDGET=2000000

# -----------------------------------------------------------------------------
# E2E / Maestro (CI only — never in production)
# -----------------------------------------------------------------------------

# E2E_STUB_AI=true
# E2E_MODE=true
# E2E_SANDBOX_PAYMENTS=true

# -----------------------------------------------------------------------------
# Disaster recovery (documented defaults)
# -----------------------------------------------------------------------------

# DR_RTO_MINUTES=60
# DR_RPO_MINUTES=15
# BACKUP_OUTPUT_DIR=./backups/mongodb
