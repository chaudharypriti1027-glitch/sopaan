PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/sopaan
JWT_SECRET=change-me-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-token-secret-min-32-chars
NODE_ENV=development
CLIENT_URL=http://localhost:8081

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
DEV_STUB_AI=true

NEWSAPI_AI_KEY=

# ---- LiveKit (live classes) ----
# Create a project at https://cloud.livekit.io → Project settings → Keys
STREAMING_PROVIDER=livekit
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_HTTP_URL=https://your-project.livekit.cloud

# ---- Recording (LiveKit egress → S3-compatible bucket) ----
# Set LIVEKIT_EGRESS_ENABLED=true after S3_* is filled.
# Cloudflare R2 example:
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_PUBLIC_BASE_URL=https://<public-bucket-host>  (R2 public bucket or custom domain)
LIVEKIT_EGRESS_ENABLED=false
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# ---- Media library (dev uploads; recordings use S3_PUBLIC_BASE_URL above) ----
MEDIA_PUBLIC_BASE_URL=
MEDIA_S3_PREFIX=media

# ---- Notifications ----
EXPO_ACCESS_TOKEN=

# ---- Payments ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Seed admin (local)
SEED_ADMIN_EMAIL=admin@sopaan.dev
SEED_ADMIN_PASSWORD=

# ---- OTP SMS ----
# dev = log OTP to server console | twilio (Messages API) | msg91
# Twilio Verify (TWILIO_VERIFY_SERVICE_SID): trial accounts SMS only verified numbers — upgrade billing for all.
# India production: MSG91 + DLT template (set SMS_PROVIDER=msg91, OTP_USE_TWILIO_VERIFY=false)
SMS_PROVIDER=dev
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
OTP_USE_TWILIO_VERIFY=true
# Pre-approved Twilio template (expiry + do-not-share). Default: HJ152393dff43d3a2c1554ab0f28291dbe
TWILIO_VERIFY_TEMPLATE_SID=
# Only for SMS_PROVIDER=twilio without Verify — E.164 sender from Twilio Console
TWILIO_FROM_NUMBER=

# ---- OTP email (SMTP) ----
# Used when users request email OTP at login. Phone OTP still uses SMS_PROVIDER.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
OTP_EMAIL_FROM=Sopaan <noreply@sopaan.app>

# ---- Performance ----
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=2
API_RATE_LIMIT_MAX=1000
CACHE_TTL_HOME_FEED_SEC=60
CACHE_TTL_SEARCH_SEC=45
CACHE_TTL_USER_STANDING_SEC=90
CACHE_TTL_ANALYTICS_SEC=60
AUTH_USER_CACHE_TTL_MS=60000
# Set REDIS_URL for shared cache + rate limits across instances
