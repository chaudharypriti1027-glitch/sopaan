PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/sopaan
JWT_SECRET=change-me-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-token-secret-min-32-chars
NODE_ENV=development
CLIENT_URL=http://localhost:8081

# Required for production AI features. If absent, AI endpoints return AI_UNAVAILABLE;
# DEV_STUB_AI is ignored/forbidden in production.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
DEV_STUB_AI=true

# Required for live external current-affairs ingestion. If absent, those routes return 503.
NEWSAPI_AI_KEY=

# ---- LiveKit (live classes) ----
# Create a project at https://cloud.livekit.io → Project settings → Keys
STREAMING_PROVIDER=livekit
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_HTTP_URL=https://your-project.livekit.cloud

# ---- Recording (LiveKit egress → S3-compatible bucket) ----
# Set LIVEKIT_EGRESS_ENABLED=true after S3_* is filled.
# Cloudflare R2 example:
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_PUBLIC_BASE_URL=https://<public-bucket-host>  (R2 public bucket or custom domain)
# AWS S3 free tier example (ap-south-1 Mumbai):
#   S3_BUCKET=your-bucket-name
#   S3_REGION=ap-south-1
#   S3_ACCESS_KEY=AKIA...           (long-term IAM user)
#   S3_SECRET_KEY=...
# Temporary STS keys (start with ASIA) also need:
#   S3_SESSION_TOKEN=...
LIVEKIT_EGRESS_ENABLED=false
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_SESSION_TOKEN=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# ---- Media library (dev uploads; recordings use S3_PUBLIC_BASE_URL above) ----
MEDIA_PUBLIC_BASE_URL=
MEDIA_S3_PREFIX=media

# ---- Notifications ----
EXPO_ACCESS_TOKEN=

# ---- Payments (optional at boot; checkout returns PAYMENTS_NOT_CONFIGURED when empty) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Welcome free month (1-month Pro on signup; admin can revoke) ----
# In production defaults to on unless set to false. Tests default to off.
WELCOME_MONTH_ON_SIGNUP=true

# Seed admin (local)
SEED_ADMIN_EMAIL=admin@sopaan.dev
SEED_ADMIN_PASSWORD=

# ---- Google Sign-In (optional; GOOGLE_AUTH_NOT_CONFIGURED when empty) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=

# ---- OTP SMS (Twilio) ----
# Phone OTP uses Twilio Verify when TWILIO_VERIFY_SERVICE_SID + credentials are set.
# SMS_PROVIDER=dev logs local OTP codes; Twilio Verify is separate.
# Production: leave unset or set twilio/msg91 — missing config returns SMS_UNAVAILABLE (503).
SMS_PROVIDER=dev
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_AUTH_TOKEN_SECONDARY=
TWILIO_TEST_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
OTP_USE_TWILIO_VERIFY=true
OTP_DEV_FALLBACK_ON_TRIAL=true
TWILIO_USE_TEST_AUTH_TOKEN=false
TWILIO_VERIFY_TEMPLATE_SID=
TWILIO_FROM_NUMBER=

# MSG91 alternative (used when SMS_PROVIDER=msg91)
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=

# ---- OTP email (SMTP / Brevo) ----
# Brevo: SMTP & API → SMTP keys → create key, use login as SMTP_USER and key as SMTP_PASS
# Production without SMTP: forgot-password / email OTP return EMAIL_UNAVAILABLE (503).
# Set OTP_EMAIL_REQUIRED=true to fail boot if SMTP is incomplete.
OTP_EMAIL_REQUIRED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
OTP_EMAIL_FROM=Sopaan <noreply@sopaan.app>

# ---- Cloudinary (avatars / uploads) ----
AVATAR_STORAGE_PROVIDER=cloudinary
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_AVATAR_FOLDER=sopaan/avatars
CLOUDINARY_UPLOAD_FOLDER=sopaan/uploads

# ---- Performance ----
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=2
API_RATE_LIMIT_MAX=1000
CACHE_TTL_HOME_FEED_SEC=60
CACHE_TTL_SEARCH_SEC=45
CACHE_TTL_USER_STANDING_SEC=90
CACHE_TTL_ANALYTICS_SEC=60
AUTH_USER_CACHE_TTL_MS=60000
# Set REDIS_URL for shared cache + rate limits across instances
REDIS_URL=
