PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/sopaan
JWT_SECRET=change-me-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-token-secret-min-32-chars
NODE_ENV=development
CLIENT_URL=http://localhost:8081

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
DEV_STUB_AI=true

NEWSAPI_AI_KEY=

# ---- LiveKit (live classes) ----
# Create a project at https://cloud.livekit.io → Project settings → Keys
STREAMING_PROVIDER=livekit
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_HTTP_URL=https://your-project.livekit.cloud

# ---- Recording (LiveKit egress → S3-compatible bucket) ----
# Set LIVEKIT_EGRESS_ENABLED=true after S3_* is filled.
# Cloudflare R2 example:
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_PUBLIC_BASE_URL=https://<public-bucket-host>  (R2 public bucket or custom domain)
LIVEKIT_EGRESS_ENABLED=false
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# ---- Media library (dev uploads; recordings use S3_PUBLIC_BASE_URL above) ----
MEDIA_PUBLIC_BASE_URL=
MEDIA_S3_PREFIX=media

# ---- Notifications ----
EXPO_ACCESS_TOKEN=

# ---- Payments ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Seed admin (local)
SEED_ADMIN_EMAIL=admin@sopaan.dev
SEED_ADMIN_PASSWORD=
