# Staging — copy to server/.env.staging (gitignored). Never use production URIs or keys here.
PORT=4000

# Dedicated Atlas staging cluster (separate from production)
MONGODB_URI=mongodb+srv://<staging-user>:<pass>@<staging-cluster>/sopaan

# Unique JWT secrets — never reuse production values
JWT_SECRET=<staging-only-min-32-chars>
JWT_REFRESH_SECRET=<staging-only-different-min-32-chars>

# Run with production hardening; distinguish via DEPLOY_ENV
NODE_ENV=production
DEPLOY_ENV=staging

# Required for parity with multi-instance production
REDIS_URL=redis://<staging-redis-host>:6379
REDIS_ENABLED=true

# Staging API URL for CORS (Expo dev or staging web client)
CLIENT_URL=https://staging-api.sopaan.app

# Anthropic — use a separate key with spend limits if possible
ANTHROPIC_API_KEY=<staging-claude-key>

# Razorpay TEST mode only
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=<razorpay-test-secret>
RAZORPAY_WEBHOOK_SECRET=<staging-webhook-secret>

# NewsAPI.ai — required in production for live current affairs
NEWSAPI_AI_KEY=<staging-newsapi-ai-key>
OBSERVABILITY_ENABLED=true
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=staging
SENTRY_RELEASE=sopaan-api@staging
SENTRY_TRACES_SAMPLE_RATE=0.2

# DR targets (same policy as prod; drills measured against these)
# DR_RTO_MINUTES=60
# DR_RPO_MINUTES=15

# Mobile force-update (staging channel for EAS Update)
# APP_MIN_NATIVE_VERSION=0.1.0
# APP_UPDATE_CHANNEL=staging

# Optional: logical backup output when running backup scripts against staging
# BACKUP_OUTPUT_DIR=./backups/mongodb-staging
