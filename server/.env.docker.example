# Local Docker Compose environment.
# Copy to server/.env.docker (gitignored) or rely on compose `environment` overrides.

NODE_ENV=development
DEPLOY_ENV=development
PORT=4000

MONGODB_URI=mongodb://mongodb:27017/sopaan
REDIS_URL=redis://redis:6379
REDIS_ENABLED=true

CLIENT_URL=http://localhost:8081

# Dev-only stubs — never use these values in production
JWT_SECRET=local-docker-jwt-secret-min-32-chars!!
JWT_REFRESH_SECRET=local-docker-refresh-secret-min-32-ch!
DEV_STUB_AI=true

JOBS_ENABLED=true
JOBS_TIMEZONE=Asia/Kolkata
PROCESS_ROLE=api

# Optional: set on worker service only (see docker-compose.yml)
# PROCESS_ROLE=worker
